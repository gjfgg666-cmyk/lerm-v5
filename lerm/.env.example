# LERM v5 - Environment Variables Template
# Copy this file to .env and fill in your values.

# ── API Security (REQUIRED for P0 auth) ────────────────────────────────────────
# Generate with: openssl rand -hex 32
LERM_API_KEY=your_secret_api_key_here

# ── Ollama (optional override) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b

# ── OpenAI (optional, for cloud fallback) ────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
